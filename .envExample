AIRFLOW_ADMIN_MAIL=<fill here>
AIRFLOW_ADMIN_FIRSTNAME=<fill here>
AIRFLOW_ADMIN_NAME=<fill here>
AIRFLOW_ADMIN_PASSWORD=<fill here>
AIRFLOW__SMTP__SMTP_HOST=mail.data.gouv.fr
AIRFLOW_POSTGRES_PORT=15432
AIRFLOW_WEBSERVER_PORT=8008
AIRFLOW_LOG_SERVER_PORT=5894
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__WEBSERVER__BASE_URL=http://localhost:$AIRFLOW_WEBSERVER_PORT
AIRFLOW__SMTP__SMTP_USER=<fill here>
AIRFLOW__SMTP__SMTP_PASSWORD=<fill here>
AIRFLOW__SMTP__SMTP_MAIL_FROM=<fill here>
AIRFLOW__CORE__LOAD_DEFAULT_CONNECTIONS=False
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgres+psycopg2://$POSTGRES_USER:$POSTGRES_PASSWORD@postgres:5432/$POSTGRES_DB
AIRFLOW__CORE__FERNET_KEY=81HqDtbqAywKSOumSha3BhWNOdQ26slT6K0YaZeZyPs=
AIRFLOW_CONN_METADATA_DB=postgres+psycopg2://$POSTGRES_USER:$POSTGRES_PASSWORD@postgres:5432/$POSTGRES_DB
AIRFLOW_VAR__METADATA_DB_SCHEMA=$POSTGRES_DB
AIRFLOW_ENV_TYPE=local
AIRFLOW_ENV_NAME=metrics

HYDRA_HOST=host.docker.internal
HYDRA_PORT=5434
HYDRA_USER=postgres
HYDRA_PASSWORD=postgres
HYDRA_DB=postgres

# udata API - usar IP remoto para instalacao distribuida
UDATA_HOST=host.docker.internal
UDATA_PORT=7000

# MongoDB - usar IP remoto para instalacao distribuida
MONGODB_HOST=host.docker.internal
MONGODB_PORT=27017

# Airflow Connections provisionadas por ambiente (substituem o antigo
# 'airflow connections import' do setup.py, que carregava a app inteira e
# era morto por OOM em hosts apertados). O Airflow le AIRFLOW_CONN_<ID>
# ao arranque; o <ID> em minusculas e o conn_id usado nos DAGs.
#   hydra_postgres_csv -> PostgresHook nos DAGs (schema = base de dados)
#   mongo_default       -> MongoHook nos DAGs
# Nota: os extras do mongo (srv/ssl/allow_insecure) sao todos os defaults do
# provider, por isso a URI simples e equivalente a connection antiga.
AIRFLOW_CONN_HYDRA_POSTGRES_CSV=postgres://$HYDRA_USER:$HYDRA_PASSWORD@$HYDRA_HOST:$HYDRA_PORT/$HYDRA_DB
AIRFLOW_CONN_MONGO_DEFAULT=mongo://$MONGODB_HOST:$MONGODB_PORT